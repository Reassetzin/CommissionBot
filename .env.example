# Bot credentials (Discord Developer Portal -> your app -> Bot tab)
DISCORD_TOKEN=

# Channel where the commission panel embed + button should live.
# The bot checks this channel's pins on every startup and posts/pins the
# panel automatically if it's not already there — no command needed.
COMMISSIONS_CHANNEL_ID=

# Role that can see tickets, gets pinged, and can use "Close Ticket".
STAFF_ROLE_ID=

# Role pinged when a new ticket opens. Defaults to STAFF_ROLE_ID if left blank.
NOTIFY_ROLE_ID=

# Category channel ID that new "commission-username" ticket channels get created under.
# Leave blank to create tickets at the top level of the server.
COMMISSIONS_CATEGORY_ID=

# Private channel ID where closed-ticket transcripts get posted.
# Leave blank to skip transcript logging.
LOG_CHANNEL_ID=

# Display name only (shown in the README / panel copy).
STAFF_ROLE_NAME=Studio Duo Team
